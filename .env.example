# ====================================================================
# theplus-ai-influencer — environment variables
# Copy to .env.local and fill in real values. .env* files are gitignored.
# ====================================================================

# --------------------------------------------------------------------
# Public app config
# --------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3002

# Local-only demo workspace. Ignored when NODE_ENV=production.
# Lets /dashboard, /studio, /create-post, and /accounts run without
# Supabase auth or paid Luma/OpenAI/Zernio calls.
THEPLUS_DEMO_MODE=

# --------------------------------------------------------------------
# Supabase — auth + database
# Project settings → API → URL + anon key + service_role key
# --------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # server-only; never expose to browser

# --------------------------------------------------------------------
# Luma — AI image generation (https://lumalabs.ai/api)
# Set LUMA_STUB=1 during dev to skip real Luma calls and return
# placeholder images (pravatar + picsum). Useful for end-to-end UI /
# Supabase / Zernio testing without burning credits.
# --------------------------------------------------------------------
LUMA_API_KEY=luma-...
LUMA_STUB=

# --------------------------------------------------------------------
# Zernio — multi-platform social scheduling (https://zernio.com)
# Sign up, then copy your API key from the dashboard.
# Promo code TUBEGURUJI per the source video.
# --------------------------------------------------------------------
ZERNIO_API_KEY=
ZERNIO_API_BASE_URL=https://zernio.com/api/v1

# --------------------------------------------------------------------
# Stripe — billing
# --------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
