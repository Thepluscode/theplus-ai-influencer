# ====================================================================
# theplus-ai-influencer — environment variables
# Copy to .env.local and fill in real values. .env* files are gitignored.
# ====================================================================

# --------------------------------------------------------------------
# Public app config
# --------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3002

# --------------------------------------------------------------------
# Demo mode — local-only fake workspace for screenshots, sales demos,
# and end-to-end UI testing without Supabase auth.
#
# When THEPLUS_DEMO_MODE=true (and NODE_ENV != 'production'):
#   * /dashboard, /studio, /create-post, /accounts etc. render with a
#     deterministic demo user + workspace; no Supabase auth required.
#   * Studio / Create / Schedule server actions return canned success
#     responses without touching Supabase, Luma, OpenAI, or Stripe.
#   * Mutating Zernio calls (createPost, deletePost, replyToComment,
#     sendDmReply) are HARD-BLOCKED at the SDK boundary — they throw
#     DemoModeBlockedError before any network call. A demo workspace
#     cannot publish, delete, reply, or DM to real connected accounts
#     even if a route forgets to short-circuit.
#   * Combine with LUMA_STUB=1 and OPENAI_STUB=1 for a fully offline
#     demo with no paid API calls at all.
#
# Fails closed in production: isDemoMode() returns false whenever
# NODE_ENV === 'production', regardless of this var. Safe to leave set.
# --------------------------------------------------------------------
THEPLUS_DEMO_MODE=

# --------------------------------------------------------------------
# Supabase — auth + database
# Project settings → API → URL + anon key + service_role key
# --------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # server-only; never expose to browser

# --------------------------------------------------------------------
# Luma — AI image / video generation (https://lumalabs.ai/api)
# Set LUMA_STUB=1 to skip real Luma calls and return placeholder
# images (pravatar + picsum). Required for offline demos.
# --------------------------------------------------------------------
LUMA_API_KEY=luma-...
LUMA_STUB=

# --------------------------------------------------------------------
# OpenAI — caption writer + cross-platform reformatter
# OPENAI_STUB=1 returns canned captions so dev / demo runs without
# burning OpenAI credits.
# --------------------------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_CAPTION_MODEL=gpt-4o-mini
OPENAI_STUB=

# --------------------------------------------------------------------
# Zernio — multi-platform social scheduling (https://zernio.com)
# Sign up, then copy your API key from the dashboard.
# ZERNIO_WEBHOOK_SECRET is the HMAC-SHA256 key Zernio signs inbound
# comment / DM webhooks with (X-Zernio-Signature). Without it the
# /api/webhooks/zernio receiver rejects every event.
# --------------------------------------------------------------------
ZERNIO_API_KEY=
ZERNIO_API_BASE_URL=https://zernio.com/api/v1
ZERNIO_WEBHOOK_SECRET=

# --------------------------------------------------------------------
# Stripe — subscriptions + credit topups
# Create the prices in the Stripe dashboard and paste the price_xxx
# ids below. STRIPE_PRICE_TOPUP is the one-off credit-pack SKU.
# --------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_STUDIO=price_...
STRIPE_PRICE_AGENCY=price_...
STRIPE_PRICE_TOPUP=price_...

# --------------------------------------------------------------------
# Cron worker auth — required in production to authenticate
# /api/jobs/storyboard-animate. Must be >= 16 chars. In dev the route
# also accepts SUPABASE_SERVICE_ROLE_KEY as a bearer token, so this
# var is optional locally.
# --------------------------------------------------------------------
CRON_SECRET=
